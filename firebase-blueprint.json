{
  "entities": {
    "Organization": {
      "title": "Organization",
      "description": "Represents the client company or system owner.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "apiKey": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this organization" }
      },
      "required": ["id", "name", "apiKey", "createdAt", "ownerId"]
    },
    "SourceSystem": {
      "title": "Source System",
      "description": "The specific application or system generating the logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "organizationId": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "environment": { "type": "string", "enum": ["PROD", "STAG", "DEV"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "organizationId", "name", "environment", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "The immutable log entry stored off-chain.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "sourceSystemId": { "type": "string", "format": "uuid" },
        "organizationId": { "type": "string", "format": "uuid" },
        "eventType": { "type": "string" },
        "contentJson": { "type": "object" },
        "hashCalculated": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "statusAnchoring": { "type": "string", "enum": ["PENDING", "ANCHORED", "FAILED"] }
      },
      "required": ["id", "sourceSystemId", "organizationId", "eventType", "contentJson", "hashCalculated", "createdAt", "statusAnchoring"]
    },
    "BlockchainProof": {
      "title": "Blockchain Proof",
      "description": "Proof of anchoring on the blockchain.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "eventId": { "type": "string", "format": "uuid" },
        "txHash": { "type": "string" },
        "blockNumber": { "type": "integer" },
        "contractAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "MINED", "FAILED"] },
        "registeredAt": { "type": "string", "format": "date-time" },
        "eventHash": { "type": "string" }
      },
      "required": ["id", "eventId", "txHash", "blockNumber", "contractAddress", "status", "registeredAt", "eventHash"]
    },
    "Audit": {
      "title": "Audit",
      "description": "Log of verification attempts.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "eventId": { "type": "string", "format": "uuid" },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "integrityResult": { "type": "boolean" },
        "auditorUser": { "type": "string" },
        "errorDetails": { "type": "string" }
      },
      "required": ["id", "eventId", "verifiedAt", "integrityResult", "auditorUser"]
    }
  },
  "firestore": {
    "/organizations/{orgId}": {
      "schema": "Organization",
      "description": "Top-level collection for organizations."
    },
    "/organizations/{orgId}/sourceSystems/{systemId}": {
      "schema": "SourceSystem",
      "description": "Systems belonging to an organization."
    },
    "/organizations/{orgId}/events/{eventId}": {
      "schema": "Event",
      "description": "Events generated by systems in an organization."
    },
    "/organizations/{orgId}/events/{eventId}/proofs/{proofId}": {
      "schema": "BlockchainProof",
      "description": "Blockchain anchoring proof for a specific event."
    },
    "/organizations/{orgId}/events/{eventId}/audits/{auditId}": {
      "schema": "Audit",
      "description": "Audits performed on an event."
    }
  }
}
